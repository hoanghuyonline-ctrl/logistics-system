# === Required ===
NEXTAUTH_SECRET="generate-a-strong-random-secret-here"
NEXTAUTH_URL="https://your-domain.com"
POSTGRES_PASSWORD="change-this-to-a-strong-password"

# === Google OAuth (optional — login page button hidden when not set) ===
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# === Email (SMTP) ===
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# === Telegram ===
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# === Zalo OA ===
ZALO_OA_ACCESS_TOKEN=""
# Zalo OA chat link for mobile support widget (e.g. https://zalo.me/1234567890)
NEXT_PUBLIC_ZALO_OA_URL=""
ZALO_RECIPIENT_ID=""
ZALO_SEND_ENABLED="false"

# === Storage Provider ===
STORAGE_PROVIDER="LOCAL"

# === Cloudflare R2 (only when STORAGE_PROVIDER=R2) ===
R2_ENDPOINT="https://<ACCOUNT_ID>.r2.cloudflarestorage.com"
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_CUSTOM_DOMAIN="https://cdn.thue.eu.cc"

# === Bank Webhook (Casso/SePay) ===
BANK_WEBHOOK_ENABLED="false"
BANK_WEBHOOK_PROVIDER="disabled"
BANK_WEBHOOK_SECRET=""
BANK_WEBHOOK_ALLOWED_ACCOUNT=""

# === Deployment ===
HTTP_PORT="80"

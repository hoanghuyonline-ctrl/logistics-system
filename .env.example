DATABASE_URL="postgresql://postgres:postgres@localhost:5432/logistics"
NEXTAUTH_SECRET="change-me-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (optional — login page button hidden when not set)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Zalo OA Notification
ZALO_OA_ACCESS_TOKEN=""

# Zalo OA chat link for mobile support widget (e.g. https://zalo.me/1234567890)
NEXT_PUBLIC_ZALO_OA_URL=""
ZALO_RECIPIENT_ID=""
ZALO_SEND_ENABLED="false"

# Storage Provider: LOCAL (default) or R2 (Cloudflare R2)
STORAGE_PROVIDER="LOCAL"

# Cloudflare R2 (only needed when STORAGE_PROVIDER=R2)
R2_ENDPOINT="https://<ACCOUNT_ID>.r2.cloudflarestorage.com"
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_CUSTOM_DOMAIN="https://cdn.thue.eu.cc"

# Bank Webhook (Casso/SePay) — automatic wallet top-up
BANK_WEBHOOK_ENABLED="false"
BANK_WEBHOOK_PROVIDER="disabled"
BANK_WEBHOOK_SECRET=""
BANK_WEBHOOK_ALLOWED_ACCOUNT=""

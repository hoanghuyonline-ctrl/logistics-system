generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CUSTOMER
  ADMIN
  WAREHOUSE_CN
  WAREHOUSE_VN
  ACCOUNTANT
}

enum OrderStatus {
  PENDING
  PURCHASED
  SELLER_SHIPPED
  ARRIVED_CHINA_WH
  PACKING
  SHIPPING_TO_VIETNAM
  ARRIVED_VIETNAM_WH
  OUT_FOR_DELIVERY
  COMPLETED
  CANCELLED
}

enum OrderPriority {
  NORMAL
  HIGH
  URGENT
}

enum OrderType {
  ECOMMERCE
  ENTRUST
  CONSIGNMENT
}

enum ShipmentStatus {
  PENDING
  RECEIVED_CHINA
  IN_CHINA_WAREHOUSE
  SHIPPED_TO_VN
  IN_VN_WAREHOUSE
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum PackageStatus {
  AT_CHINA_WH
  SHIPPING
  AT_VIETNAM_WH
  DELIVERED
}

enum TransactionType {
  DEPOSIT
  ORDER_PAYMENT
  REFUND
  ADJUSTMENT
  SALES_PAYMENT
  MANUAL_ADD
  MANUAL_DEDUCT
}

enum SalesRequestStatus {
  NEW
  CONTACTED
  PRICE_CONFIRMED
  PAID
  PROCESSING
  COMPLETED
  CANCELLED
}

enum NotificationType {
  EMAIL
  TELEGRAM
  SYSTEM
  ZALO
}

enum TransportServiceType {
  TRUCK_NORTH_SOUTH
  INNER_CITY_DELIVERY
  TRANSIT_WAREHOUSE
}

enum TransportRequestStatus {
  PENDING
  REVIEWING
  QUOTED
  CONFIRMED
  IN_TRANSIT
  DELIVERED
  COMPLETED
  CANCELLED
}

enum QuotationServiceType {
  IMPORT_EXPORT
  CUSTOMS_CLEARANCE
  DOMESTIC_TRANSPORT
  WAREHOUSE_STORAGE
  INTERNATIONAL_TRADE
  OTHER
}

enum QuotationStatus {
  NEW
  CONTACTED
  QUOTED
  ACCEPTED
  REJECTED
  EXPIRED
}

enum KnowledgeCategory {
  IMPORT_POLICY
  EXPORT_TAX
  HS_CODE
  LOGISTICS_NEWS
  EXPORT_GUIDE
  INCOTERMS
  VIETNAM_PORTS
}

enum CustomsDeclarationType {
  KINH_DOANH
  GIA_CONG
  SAN_XUAT_XUAT_KHAU
  TAM_NHAP_TAI_XUAT
  PHI_MAU_DICH
}

enum CustomsRequestStatus {
  PENDING
  REVIEWING
  QUOTED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum LeadSource {
  ZALO
  FACEBOOK
  WEBSITE
  REFERRAL
  OTHER
}

enum LeadStatus {
  NEW
  CONTACTED
  INTERESTED
  CONVERTED
  LOST
}

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  password       String
  fullName       String
  phone          String?  @unique
  address        String?
  avatarUrl      String?
  role           Role     @default(CUSTOMER)
  isActive       Boolean  @default(true)
  telegramChatId  String?
  zaloRecipientId String?
  createdAt       DateTime @default(now())
  updatedAt      DateTime @updatedAt

  wallet             Wallet?
  orders             Order[]
  transactions       Transaction[]
  notifications      Notification[]
  orderStatusChanges OrderStatusLog[] @relation("StatusChanger")
  orderNotes         OrderNote[]
  packagesCreated    Package[]        @relation("PackageCreator")
  configChanges      SystemConfig[]
  transactionsCreated Transaction[]   @relation("TransactionCreator")
  customerIssues     CustomerIssue[]  @relation("CustomerIssues")
  assignedIssues     CustomerIssue[]  @relation("AssignedIssues")
  staffNotes         StaffNote[]      @relation("StaffNotes")
  topUpRequests      WalletTopUpRequest[] @relation("TopUpRequests")
  topUpConfirmations WalletTopUpRequest[] @relation("TopUpConfirmations")
  assignedLeads      Lead[]               @relation("LeadAssignee")
  convertedFromLeads Lead[]               @relation("LeadConvertedUser")
  leadActivities     LeadActivity[]       @relation("LeadActivityActor")
  campaigns          Campaign[]           @relation("CampaignCreator")
  salesRequests      SalesRequest[]       @relation("SalesRequestCustomer")
  salesConfirmations SalesRequest[]       @relation("SalesRequestConfirmer")
  productsCreated    Product[]            @relation("ProductCreator")
  customsRequests    CustomsRequest[]     @relation("CustomsRequests")
  knowledgeArticles  KnowledgeArticle[]   @relation("KnowledgeAuthor")
  transportRequests  TransportRequest[]   @relation("TransportRequests")
  quotationResponses QuotationRequest[]   @relation("QuotationResponder")
}

model Wallet {
  id        String   @id @default(uuid())
  userId    String   @unique
  balance   Decimal  @default(0) @db.Decimal(15, 2)
  debt      Decimal  @default(0) @db.Decimal(15, 2)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Order {
  id                        String      @id @default(uuid())
  orderCode                 String      @unique
  userId                    String
  packageId                 String?
  productName               String
  productLink               String
  orderType                 OrderType   @default(ECOMMERCE)
  productImage              String?
  productSpecs              String?
  quantity                  Int
  unitPriceCNY              Decimal     @db.Decimal(10, 2)
  totalPriceCNY             Decimal     @db.Decimal(12, 2)
  exchangeRate              Decimal     @db.Decimal(10, 2)
  totalPriceVND             Decimal     @db.Decimal(15, 2)
  serviceFeePercent         Decimal     @db.Decimal(5, 2)
  serviceFeeVND             Decimal     @db.Decimal(15, 2)
  chinaShippingFee          Decimal     @default(0) @db.Decimal(15, 2)
  weightKg                  Decimal?    @db.Decimal(8, 3)
  volume                    Decimal?    @db.Decimal(8, 3)
  requiresVat               Boolean     @default(false)
  taxCode                   String?
  companyName               String?
  companyAddress             String?
  // Enhanced entrust fields
  entrustShipmentType       String?     // FCL or LCL
  entrustServices           String?     // JSON array of selected services
  cargoValueCurrency        String?     // USD or CNY
  cargoValueAmount          Decimal?    @db.Decimal(15, 2)
  cargoValueVND             Decimal?    @db.Decimal(15, 2)
  dimensionLength           Decimal?    @db.Decimal(8, 2)
  dimensionWidth            Decimal?    @db.Decimal(8, 2)
  dimensionHeight           Decimal?    @db.Decimal(8, 2)
  cbm                       Decimal?    @db.Decimal(10, 4)
  entrustQuantity           Int?
  waybillCode               String?
  waybillImages             String?     // JSON array of image URLs
  relatedDocuments          String?     // JSON array of document URLs
  cnTruckPlate              String?
  cnDriverName              String?
  cnDriverPhone             String?
  cnTruckImages             String?     // JSON array of truck photo URLs
  // Consignment fields
  consignmentTrackingNumber String?
  consignmentNotes          String?
  // Shipping address (e.g. China warehouse address)
  shippingAddress           String?     @db.Text
  internationalShippingRate Decimal     @db.Decimal(10, 2)
  internationalShippingFee  Decimal     @default(0) @db.Decimal(15, 2)
  vietnamDeliveryFee        Decimal     @default(0) @db.Decimal(15, 2)
  totalCostVND              Decimal     @db.Decimal(15, 2)
  confirmedProductCost      Decimal?    @db.Decimal(15, 2)
  confirmedShippingCost     Decimal?    @db.Decimal(15, 2)
  confirmedServiceFee       Decimal?    @db.Decimal(15, 2)
  confirmedTotalCost        Decimal?    @db.Decimal(15, 2)
  confirmedAt               DateTime?
  confirmedById             String?
  status                    OrderStatus @default(PENDING)
  priority                  OrderPriority @default(NORMAL)
  trackingCodeChina         String?
  trackingCodeIntl          String?
  notes                     String?
  customStatusNote          String?
  createdAt                 DateTime    @default(now())
  updatedAt                 DateTime    @updatedAt

  user          User             @relation(fields: [userId], references: [id])
  package       Package?         @relation(fields: [packageId], references: [id])
  statusLogs    OrderStatusLog[]
  orderNotes    OrderNote[]
  transactions  Transaction[]
  notifications Notification[]
  salesRequests SalesRequest[]
}

model OrderStatusLog {
  id         String      @id @default(uuid())
  orderId    String
  fromStatus OrderStatus?
  toStatus   OrderStatus
  changedBy  String
  note       String?
  createdAt  DateTime    @default(now())

  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  changer User  @relation("StatusChanger", fields: [changedBy], references: [id])
}

model OrderNote {
  id        String   @id @default(uuid())
  orderId   String
  userId    String
  content   String
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])
}

model Package {
  id            String        @id @default(uuid())
  packageCode   String        @unique
  barcode       String?
  totalWeightKg Decimal?      @db.Decimal(8, 3)
  lengthCm      Decimal?      @db.Decimal(8, 2)
  widthCm       Decimal?      @db.Decimal(8, 2)
  heightCm      Decimal?      @db.Decimal(8, 2)
  status        PackageStatus @default(AT_CHINA_WH)
  createdBy     String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  creator  User           @relation("PackageCreator", fields: [createdBy], references: [id])
  orders   Order[]
  images   PackageImage[]
}

model PackageImage {
  id        String   @id @default(uuid())
  packageId String
  imageUrl  String
  createdAt DateTime @default(now())

  package Package @relation(fields: [packageId], references: [id], onDelete: Cascade)
}

model Transaction {
  id            String          @id @default(uuid())
  userId        String
  type          TransactionType
  amount        Decimal         @db.Decimal(15, 2)
  balanceBefore Decimal         @db.Decimal(15, 2)
  balanceAfter  Decimal         @db.Decimal(15, 2)
  orderId       String?
  description   String?
  createdBy     String
  createdAt     DateTime        @default(now())

  user    User   @relation(fields: [userId], references: [id])
  order   Order? @relation(fields: [orderId], references: [id])
  creator User   @relation("TransactionCreator", fields: [createdBy], references: [id])
}

model SystemConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedBy String
  updatedAt DateTime @updatedAt

  updater User @relation(fields: [updatedBy], references: [id])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  title     String
  message   String
  type      NotificationType @default(SYSTEM)
  isRead    Boolean          @default(false)
  orderId   String?
  createdAt DateTime         @default(now())

  user  User   @relation(fields: [userId], references: [id])
  order Order? @relation(fields: [orderId], references: [id])
}

model NotificationFailure {
  id              String   @id @default(uuid())
  channel         String
  orderCode       String?
  customerId      String?
  recipient       String?
  failureCategory String?
  shortReason     String?
  payloadSummary  String?
  retryCount      Int      @default(0)
  lastRetryAt     DateTime?
  resolved        Boolean  @default(false)
  createdAt       DateTime @default(now())
}

model SupportKnowledge {
  id             String    @id @default(uuid())
  title          String
  content        String
  category       String
  keywords       String?
  isActive       Boolean   @default(true)
  matchCount     Int       @default(0)
  matchCountZalo Int       @default(0)
  matchCountTelegram Int   @default(0)
  matchCountMessenger Int  @default(0)
  lastMatchedAt  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model ChatbotUnansweredQuestion {
  id        String   @id @default(uuid())
  channel   String
  question  String
  senderId  String?
  resolved  Boolean  @default(false)
  category  String?
  createdAt DateTime @default(now())
}

model CustomerIssue {
  id          String   @id @default(uuid())
  customerId  String
  orderCode   String?
  issueType   String
  description String
  status      String   @default("NEW")
  priority    String   @default("NORMAL")
  assignedTo  String?
  resolution  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer User  @relation("CustomerIssues", fields: [customerId], references: [id])
  assignee User? @relation("AssignedIssues", fields: [assignedTo], references: [id])
}

model StaffNote {
  id         String   @id @default(uuid())
  title      String
  content    String
  orderCode  String?
  priority   String   @default("NORMAL")
  resolved   Boolean  @default(false)
  createdBy  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  author User @relation("StaffNotes", fields: [createdBy], references: [id])
}

model BankWebhookLog {
  id                String   @id @default(uuid())
  provider          String
  transactionId     String
  rawPayload        String
  status            String   @default("RECEIVED")
  transferReference String?
  amount            Decimal? @db.Decimal(15, 2)
  accountNumber     String?
  transactionTime   DateTime?
  errorReason       String?
  topUpRequestId    String?
  createdAt         DateTime @default(now())

  @@unique([provider, transactionId])
}

model WalletTopUpRequest {
  id                String   @id @default(uuid())
  customerId        String
  amount            Decimal  @db.Decimal(15, 2)
  transferReference String
  bankName          String
  bankAccount       String
  accountHolder     String
  status            String   @default("PENDING")
  confirmedBy       String?
  confirmedAt       DateTime?
  createdAt         DateTime @default(now())

  customer  User  @relation("TopUpRequests", fields: [customerId], references: [id])
  confirmer User? @relation("TopUpConfirmations", fields: [confirmedBy], references: [id])
}

model Lead {
  id               String     @id @default(uuid())
  fullName         String
  phone            String?
  email            String?
  zaloName         String?
  facebookName     String?
  zaloSenderId     String?    @unique
  facebookSenderId String?    @unique
  source           LeadSource @default(OTHER)
  status           LeadStatus @default(NEW)
  isAutoCreated    Boolean    @default(false)
  notes            String?    @db.Text
  assignedToId     String?
  convertedUserId  String?
  nextFollowUpAt   DateTime?
  lastContactedAt  DateTime?
  followUpNote     String?    @db.Text
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  assignedTo    User?          @relation("LeadAssignee", fields: [assignedToId], references: [id])
  convertedUser User?          @relation("LeadConvertedUser", fields: [convertedUserId], references: [id])
  activities    LeadActivity[]
}

model LeadActivity {
  id        String   @id @default(uuid())
  leadId    String
  action    String
  detail    String?
  actorId   String?
  createdAt DateTime @default(now())

  lead  Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  actor User? @relation("LeadActivityActor", fields: [actorId], references: [id])

  @@index([leadId, createdAt])
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum CampaignChannel {
  ZALO
  FACEBOOK
  EMAIL
  SMS
}

model Campaign {
  id              String          @id @default(uuid())
  name            String
  channel         CampaignChannel
  status          CampaignStatus  @default(DRAFT)
  targetStatus    String?
  messageTemplate String?         @db.Text
  scheduledAt     DateTime?
  notes           String?         @db.Text
  createdById     String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  createdBy User? @relation("CampaignCreator", fields: [createdById], references: [id])
}

model Product {
  id             String   @id @default(uuid())
  name           String
  description    String?  @db.Text
  category       String?
  estimatedPrice Decimal? @db.Decimal(15, 2)
  imageUrl       String?
  images         Json?
  variants       Json?
  specs          Json?
  isActive       Boolean  @default(true)
  sortOrder      Int      @default(0)
  createdById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  createdBy     User?          @relation("ProductCreator", fields: [createdById], references: [id])
  salesRequests SalesRequest[]
}

model SalesRequest {
  id              String             @id @default(uuid())
  requestCode     String             @unique
  customerId      String
  productId       String?
  productName     String
  quantity        Int                @default(1)
  estimatedTotal  Decimal?           @db.Decimal(15, 2)
  confirmedPrice  Decimal?           @db.Decimal(15, 2)
  status          SalesRequestStatus @default(NEW)
  adminNote       String?            @db.Text
  customerNote    String?            @db.Text
  selectedOptions String?
  paidAt          DateTime?
  paidFromWallet  Boolean            @default(false)
  paymentMethod   String             @default("WALLET")
  confirmedById   String?
  confirmedAt     DateTime?
  orderId         String?
  shippingName    String?
  shippingPhone   String?
  shippingAddress String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  customer    User     @relation("SalesRequestCustomer", fields: [customerId], references: [id])
  product     Product? @relation(fields: [productId], references: [id])
  confirmedBy User?    @relation("SalesRequestConfirmer", fields: [confirmedById], references: [id])
  order       Order?   @relation(fields: [orderId], references: [id])

  @@index([customerId, createdAt])
  @@index([status])
}

model CustomsRequest {
  id                String                  @id @default(uuid())
  requestCode       String                  @unique
  customerId        String
  declarationType   CustomsDeclarationType
  status            CustomsRequestStatus    @default(PENDING)
  // Accompanying services (JSON array of selected services)
  accompanyingServices String?
  // Cargo details
  goodsDescription  String?                 @db.Text
  hsCode            String?
  goodsValue        Decimal?                @db.Decimal(15, 2)
  goodsCurrency     String?
  goodsWeight       Decimal?                @db.Decimal(10, 3)
  goodsQuantity     Int?
  originCountry     String?
  destinationPort   String?
  // Company info
  companyName       String?
  taxCode           String?
  companyAddress    String?
  contactName       String?
  contactPhone      String?
  contactEmail      String?
  // Documents
  documents         String?                 // JSON array of uploaded document URLs
  // Pricing
  quotedPrice       Decimal?                @db.Decimal(15, 2)
  quotedAt          DateTime?
  // Notes
  customerNote      String?                 @db.Text
  adminNote         String?                 @db.Text
  // Timestamps
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  customer User @relation("CustomsRequests", fields: [customerId], references: [id])

  @@index([customerId, createdAt])
  @@index([status])
  @@index([declarationType])
}

model KnowledgeArticle {
  id            String            @id @default(uuid())
  slug          String            @unique
  title         String
  summary       String?           @db.Text
  content       String            @db.Text
  category      KnowledgeCategory
  coverImage    String?
  tags          String?
  isPublished   Boolean           @default(false)
  viewCount     Int               @default(0)
  authorId      String
  publishedAt   DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  author User @relation("KnowledgeAuthor", fields: [authorId], references: [id])

  @@index([category, isPublished])
  @@index([slug])
  @@index([isPublished, publishedAt])
}

model TransportRequest {
  id                String                  @id @default(uuid())
  requestCode       String                  @unique
  customerId        String
  serviceType       TransportServiceType
  status            TransportRequestStatus  @default(PENDING)
  // Pickup
  pickupAddress     String?                 @db.Text
  pickupCity        String?
  pickupContactName String?
  pickupContactPhone String?
  pickupDate        DateTime?
  // Delivery
  deliveryAddress   String?                 @db.Text
  deliveryCity      String?
  deliveryContactName String?
  deliveryContactPhone String?
  // Cargo
  cargoDescription  String?                 @db.Text
  cargoWeight       Decimal?                @db.Decimal(10, 3)
  cargoVolume       Decimal?                @db.Decimal(10, 3)
  cargoQuantity     Int?
  cargoType         String?
  requiresRefrigeration Boolean             @default(false)
  // Warehouse (for TRANSIT_WAREHOUSE)
  warehouseCity     String?
  storageDuration   Int?
  storageNote       String?                 @db.Text
  // Pricing
  quotedPrice       Decimal?                @db.Decimal(15, 2)
  quotedAt          DateTime?
  // Notes
  customerNote      String?                 @db.Text
  adminNote         String?                 @db.Text
  // Timestamps
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  customer User @relation("TransportRequests", fields: [customerId], references: [id])

  @@index([customerId, createdAt])
  @@index([status])
  @@index([serviceType])
}

model QuotationRequest {
  id              String                @id @default(uuid())
  requestCode     String                @unique
  status          QuotationStatus       @default(NEW)
  // Service
  serviceType     QuotationServiceType
  serviceDetail   String?               @db.Text
  // Cargo
  cargoDescription String?              @db.Text
  cargoWeight     Decimal?              @db.Decimal(10, 3)
  cargoVolume     Decimal?              @db.Decimal(10, 3)
  originCity      String?
  destinationCity String?
  // Contact
  contactName     String
  contactEmail    String
  contactPhone    String
  companyName     String?
  // Response
  quotedPrice     Decimal?              @db.Decimal(15, 2)
  quotedNote      String?               @db.Text
  quotedAt        DateTime?
  adminNote       String?               @db.Text
  respondedBy     String?
  // Timestamps
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  responder User? @relation("QuotationResponder", fields: [respondedBy], references: [id])

  @@index([status])
  @@index([serviceType])
  @@index([contactEmail])
}

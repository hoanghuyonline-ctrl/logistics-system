generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CUSTOMER
  ADMIN
  WAREHOUSE_CN
  WAREHOUSE_VN
  ACCOUNTANT
}

enum OrderStatus {
  PENDING
  PURCHASED
  SELLER_SHIPPED
  ARRIVED_CHINA_WH
  PACKING
  SHIPPING_TO_VIETNAM
  ARRIVED_VIETNAM_WH
  OUT_FOR_DELIVERY
  COMPLETED
  CANCELLED
}

enum OrderPriority {
  NORMAL
  HIGH
  URGENT
}

enum ShipmentStatus {
  PENDING
  RECEIVED_CHINA
  IN_CHINA_WAREHOUSE
  SHIPPED_TO_VN
  IN_VN_WAREHOUSE
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum PackageStatus {
  AT_CHINA_WH
  SHIPPING
  AT_VIETNAM_WH
  DELIVERED
}

enum TransactionType {
  DEPOSIT
  ORDER_PAYMENT
  REFUND
  ADJUSTMENT
}

enum NotificationType {
  EMAIL
  TELEGRAM
  SYSTEM
  ZALO
}

enum LeadSource {
  ZALO
  FACEBOOK
  WEBSITE
  REFERRAL
  OTHER
}

enum LeadStatus {
  NEW
  CONTACTED
  INTERESTED
  CONVERTED
  LOST
}

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  password       String
  fullName       String
  phone          String?
  address        String?
  role           Role     @default(CUSTOMER)
  isActive       Boolean  @default(true)
  telegramChatId  String?
  zaloRecipientId String?
  createdAt       DateTime @default(now())
  updatedAt      DateTime @updatedAt

  wallet             Wallet?
  orders             Order[]
  transactions       Transaction[]
  notifications      Notification[]
  orderStatusChanges OrderStatusLog[] @relation("StatusChanger")
  orderNotes         OrderNote[]
  packagesCreated    Package[]        @relation("PackageCreator")
  configChanges      SystemConfig[]
  transactionsCreated Transaction[]   @relation("TransactionCreator")
  customerIssues     CustomerIssue[]  @relation("CustomerIssues")
  assignedIssues     CustomerIssue[]  @relation("AssignedIssues")
  staffNotes         StaffNote[]      @relation("StaffNotes")
  topUpRequests      WalletTopUpRequest[] @relation("TopUpRequests")
  topUpConfirmations WalletTopUpRequest[] @relation("TopUpConfirmations")
  assignedLeads      Lead[]               @relation("LeadAssignee")
  convertedFromLeads Lead[]               @relation("LeadConvertedUser")
  leadActivities     LeadActivity[]       @relation("LeadActivityActor")
}

model Wallet {
  id        String   @id @default(uuid())
  userId    String   @unique
  balance   Decimal  @default(0) @db.Decimal(15, 2)
  debt      Decimal  @default(0) @db.Decimal(15, 2)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Order {
  id                        String      @id @default(uuid())
  orderCode                 String      @unique
  userId                    String
  packageId                 String?
  productName               String
  productLink               String
  productImage              String?
  quantity                  Int
  unitPriceCNY              Decimal     @db.Decimal(10, 2)
  totalPriceCNY             Decimal     @db.Decimal(12, 2)
  exchangeRate              Decimal     @db.Decimal(10, 2)
  totalPriceVND             Decimal     @db.Decimal(15, 2)
  serviceFeePercent         Decimal     @db.Decimal(5, 2)
  serviceFeeVND             Decimal     @db.Decimal(15, 2)
  chinaShippingFee          Decimal     @default(0) @db.Decimal(15, 2)
  weightKg                  Decimal?    @db.Decimal(8, 3)
  internationalShippingRate Decimal     @db.Decimal(10, 2)
  internationalShippingFee  Decimal     @default(0) @db.Decimal(15, 2)
  vietnamDeliveryFee        Decimal     @default(0) @db.Decimal(15, 2)
  totalCostVND              Decimal     @db.Decimal(15, 2)
  status                    OrderStatus @default(PENDING)
  priority                  OrderPriority @default(NORMAL)
  trackingCodeChina         String?
  trackingCodeIntl          String?
  notes                     String?
  customStatusNote          String?
  createdAt                 DateTime    @default(now())
  updatedAt                 DateTime    @updatedAt

  user         User             @relation(fields: [userId], references: [id])
  package      Package?         @relation(fields: [packageId], references: [id])
  statusLogs   OrderStatusLog[]
  orderNotes   OrderNote[]
  transactions Transaction[]
  notifications Notification[]
}

model OrderStatusLog {
  id         String      @id @default(uuid())
  orderId    String
  fromStatus OrderStatus?
  toStatus   OrderStatus
  changedBy  String
  note       String?
  createdAt  DateTime    @default(now())

  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  changer User  @relation("StatusChanger", fields: [changedBy], references: [id])
}

model OrderNote {
  id        String   @id @default(uuid())
  orderId   String
  userId    String
  content   String
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])
}

model Package {
  id            String        @id @default(uuid())
  packageCode   String        @unique
  barcode       String?
  totalWeightKg Decimal?      @db.Decimal(8, 3)
  lengthCm      Decimal?      @db.Decimal(8, 2)
  widthCm       Decimal?      @db.Decimal(8, 2)
  heightCm      Decimal?      @db.Decimal(8, 2)
  status        PackageStatus @default(AT_CHINA_WH)
  createdBy     String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  creator  User           @relation("PackageCreator", fields: [createdBy], references: [id])
  orders   Order[]
  images   PackageImage[]
}

model PackageImage {
  id        String   @id @default(uuid())
  packageId String
  imageUrl  String
  createdAt DateTime @default(now())

  package Package @relation(fields: [packageId], references: [id], onDelete: Cascade)
}

model Transaction {
  id            String          @id @default(uuid())
  userId        String
  type          TransactionType
  amount        Decimal         @db.Decimal(15, 2)
  balanceBefore Decimal         @db.Decimal(15, 2)
  balanceAfter  Decimal         @db.Decimal(15, 2)
  orderId       String?
  description   String?
  createdBy     String
  createdAt     DateTime        @default(now())

  user    User   @relation(fields: [userId], references: [id])
  order   Order? @relation(fields: [orderId], references: [id])
  creator User   @relation("TransactionCreator", fields: [createdBy], references: [id])
}

model SystemConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedBy String
  updatedAt DateTime @updatedAt

  updater User @relation(fields: [updatedBy], references: [id])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  title     String
  message   String
  type      NotificationType @default(SYSTEM)
  isRead    Boolean          @default(false)
  orderId   String?
  createdAt DateTime         @default(now())

  user  User   @relation(fields: [userId], references: [id])
  order Order? @relation(fields: [orderId], references: [id])
}

model NotificationFailure {
  id              String   @id @default(uuid())
  channel         String
  orderCode       String?
  customerId      String?
  recipient       String?
  failureCategory String?
  shortReason     String?
  payloadSummary  String?
  retryCount      Int      @default(0)
  lastRetryAt     DateTime?
  resolved        Boolean  @default(false)
  createdAt       DateTime @default(now())
}

model SupportKnowledge {
  id             String    @id @default(uuid())
  title          String
  content        String
  category       String
  keywords       String?
  isActive       Boolean   @default(true)
  matchCount     Int       @default(0)
  matchCountZalo Int       @default(0)
  matchCountTelegram Int   @default(0)
  matchCountMessenger Int  @default(0)
  lastMatchedAt  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model ChatbotUnansweredQuestion {
  id        String   @id @default(uuid())
  channel   String
  question  String
  senderId  String?
  resolved  Boolean  @default(false)
  category  String?
  createdAt DateTime @default(now())
}

model CustomerIssue {
  id          String   @id @default(uuid())
  customerId  String
  orderCode   String?
  issueType   String
  description String
  status      String   @default("NEW")
  assignedTo  String?
  resolution  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer User  @relation("CustomerIssues", fields: [customerId], references: [id])
  assignee User? @relation("AssignedIssues", fields: [assignedTo], references: [id])
}

model StaffNote {
  id         String   @id @default(uuid())
  title      String
  content    String
  orderCode  String?
  priority   String   @default("NORMAL")
  resolved   Boolean  @default(false)
  createdBy  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  author User @relation("StaffNotes", fields: [createdBy], references: [id])
}

model BankWebhookLog {
  id                String   @id @default(uuid())
  provider          String
  transactionId     String
  rawPayload        String
  status            String   @default("RECEIVED")
  transferReference String?
  amount            Decimal? @db.Decimal(15, 2)
  accountNumber     String?
  transactionTime   DateTime?
  errorReason       String?
  topUpRequestId    String?
  createdAt         DateTime @default(now())

  @@unique([provider, transactionId])
}

model WalletTopUpRequest {
  id                String   @id @default(uuid())
  customerId        String
  amount            Decimal  @db.Decimal(15, 2)
  transferReference String
  bankName          String
  bankAccount       String
  accountHolder     String
  status            String   @default("PENDING")
  confirmedBy       String?
  confirmedAt       DateTime?
  createdAt         DateTime @default(now())

  customer  User  @relation("TopUpRequests", fields: [customerId], references: [id])
  confirmer User? @relation("TopUpConfirmations", fields: [confirmedBy], references: [id])
}

model Lead {
  id               String     @id @default(uuid())
  fullName         String
  phone            String?
  email            String?
  zaloName         String?
  facebookName     String?
  zaloSenderId     String?    @unique
  facebookSenderId String?    @unique
  source           LeadSource @default(OTHER)
  status           LeadStatus @default(NEW)
  isAutoCreated    Boolean    @default(false)
  notes            String?    @db.Text
  assignedToId     String?
  convertedUserId  String?
  nextFollowUpAt   DateTime?
  lastContactedAt  DateTime?
  followUpNote     String?    @db.Text
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  assignedTo    User?          @relation("LeadAssignee", fields: [assignedToId], references: [id])
  convertedUser User?          @relation("LeadConvertedUser", fields: [convertedUserId], references: [id])
  activities    LeadActivity[]
}

model LeadActivity {
  id        String   @id @default(uuid())
  leadId    String
  action    String
  detail    String?
  actorId   String?
  createdAt DateTime @default(now())

  lead  Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  actor User? @relation("LeadActivityActor", fields: [actorId], references: [id])

  @@index([leadId, createdAt])
}
